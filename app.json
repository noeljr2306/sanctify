{
  "expo": {
    "name": "Sanctify",
    "slug": "sanctify",
    "version": "1.0.0",
    "scheme": "sanctify",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#6B21A8",
          "sounds": []
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alto.sanctify"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.alto.sanctify"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "852414df-b073-4b12-9662-5ad559813e96"
      }
    }
  }
}
